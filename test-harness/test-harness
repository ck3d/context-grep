#!/usr/bin/env bash

set -e

if [ $# -lt 1 ]; then
  echo "Usage: $0 <executable-or-nix-target>"
  exit 1
fi

target="$1"

# If target is a relative path, resolve it to an absolute path so it still works after we change directory
if [[ "$target" != \#* && -e "$target" ]]; then
  target="$(realpath "$target")"
fi

# Build the invocation once: a nix flake target (starting with '.' or '#') is
# run via `nix run`; anything else is treated as an executable.
if [[ "$target" == [.\#]* ]]; then
  cmd=(nix run "$target" --)
else
  cmd=("$target")
fi

# The neovim target emits JSON itself; every other target needs --format json.
extra_args=()
[[ "$target" == *nvim* ]] || extra_args=(--format json)

# Default SAMPLE_DIR to the directory where the script is located
SAMPLE_DIR="${SAMPLE_DIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/sample-data}"

cd "$SAMPLE_DIR"

# validate_schema NAME OUTPUT
#   Checks that OUTPUT conforms to the context-grep JSON schema (SCHEMA_FILE).
#   Prints the validation errors and exits on failure.
validate_schema() {
  local name="$1" output="$2"
  local tmp
  tmp="$(mktemp)"
  printf '%s' "$output" >"$tmp"

  if yajsv -q -s "$SCHEMA_FILE" "$tmp" >/dev/null; then
    echo "✓ Schema: $name ($target)"
    rm -f "$tmp"
  else
    echo "✗ Schema: $name ($target)"
    yajsv -s "$SCHEMA_FILE" "$tmp"
    rm -f "$tmp"
    exit 1
  fi
}

# run_test NAME QUERY FILES ASSERTION
#   Runs context-grep and checks ASSERTION (a jaq boolean filter) against the
#   JSON output. Prints the output and exits on failure.
run_test() {
  local name="$1" query="$2" files="$3" assertion="$4"
  echo "Testing: $name ($target)"
  local output

  # shellcheck disable=SC2086
  output=$("${cmd[@]}" "${extra_args[@]}" "$query" $files)

  if jaq -e "$assertion" >/dev/null <<<"$output"; then
    echo "✓ Success: $name ($target)"
  else
    echo "✗ Failure: $name ($target)"
    jaq . <<<"$output"
    exit 1
  fi

  validate_schema "$name" "$output"
}

# run_failure_test NAME QUERY FILES
#   Runs context-grep and asserts it exits with a non-zero status (e.g. when a
#   requested file does not exist). Prints the output and exits on failure.
run_failure_test() {
  local name="$1" query="$2" files="$3"
  echo "Testing: $name ($target)"
  local status=0

  # shellcheck disable=SC2086
  "${cmd[@]}" "${extra_args[@]}" "$query" $files >/dev/null 2>&1 || status=$?

  if [ "$status" -ne 0 ]; then
    echo "✓ Success: $name ($target)"
  else
    echo "✗ Failure: $name ($target) — expected non-zero exit code, got $status"
    exit 1
  fi
}

run_failure_test "missing file" "anything" "does-not-exist.lua"

run_test "match this" "match this" "sample.lua" \
  '(.[0].target.text | contains("local function bar()")) and .[0].file == "sample.lua"'

run_test "inner comment" "inner comment" "sample.lua" \
  '.[0].target.text == "return x"'

run_test "trailing comment" "trailing" "sample.lua" \
  '.[0].target.text == "local y = 1"'

run_test "multiple files" "TODO" "sample.lua sample2.lua" \
  'length >= 4'

# Injected languages: a TODO inside a fenced Python block in a Markdown file
# must resolve in the injected language, and the context must span both the
# outer (markdown) and inner (python) scopes.
run_test "injected language" "TODO" "sample.md" \
  '.[0].match.language == "python"
   and (.[0].context | map(.language) | contains(["markdown", "python"]))
   and (.[0].context[-1].text | contains("def process"))'
